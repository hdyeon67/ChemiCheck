# 케미체크 환경변수 (모두 선택 사항 — 없어도 앱은 정상 동작합니다)

# 카카오톡 공유 버튼 활성화용 JavaScript 키
# https://developers.kakao.com > 내 애플리케이션 > 앱 키 > JavaScript 키
# 미설정 시 카카오 버튼은 "준비 중" 안내로 대체됩니다.
NEXT_PUBLIC_KAKAO_JS_KEY=

# 카카오 애드핏(AdFit) — 실제 광고 단위 ID는 components/AdRails.tsx 에 기본값으로
# 들어가 있습니다. 아래 env를 채우면 그 값으로 override 됩니다(예: 스테이징 계정).
# 배치: 웹(데스크톱)=화면 좌·우 세로 광고, 앱(모바일)=화면 하단 가로 광고
NEXT_PUBLIC_ADFIT_UNIT_SIDE_LEFT=   # 데스크톱 좌측 세로 (160x600)
NEXT_PUBLIC_ADFIT_UNIT_SIDE_RIGHT=  # 데스크톱 우측 세로 (160x600)
NEXT_PUBLIC_ADFIT_UNIT_MOBILE=      # 모바일 하단 가로 (320x100)
